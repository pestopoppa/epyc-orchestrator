# Logs and runtime data
logs/
*.log

# Caches
cache/
share/
state/
__pycache__/
*.pyc

# Backups
backups/

# Temporary files
tmp/
*.tmp
*.swp
*~

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.sublime-*

# Claude Code config (contains credentials and session data)
config/

# Embedded git repos (cloned research repos)
research/eagle-official/
research/frspec/
research/specmquant/
*.BAK

# Orchestration transient files
orchestration/last_task_ir.json
orchestration/last_architecture_ir.json
orchestration/gate_report_*.json

# Python
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/

# Tool plugin settings (per-user configuration)
src/tool_settings/

# Large MemRL data files (stored locally)
orchestration/repl_memory/embeddings.npy
orchestration/repl_memory/episodic.db

# Local-only directories (not for GitHub)
# These contain work-in-progress, internal notes, and session logs
logs/
progress/
handoffs/
research/
kernel-dev/
test_images/

# Tool session data
.claude/
.aider*
.devcontainer/
OPENING_PROMPT.md

# Raw benchmark data (keep locally, not on GitHub)
# Human-readable summaries (RESULTS.md, BLIND_RESCORE, summary.csv) stay tracked
benchmarks/results/runs/
benchmarks/evidence/
benchmarks/results/reviews/*.csv
!benchmarks/results/reviews/summary.csv
benchmarks/results/orchestrator/

# Benchmark question pools (reconstructible from public sources — see Ch24)
# Use wildcard pattern to allow negation of specific files
benchmarks/prompts/*
# EXCEPT: Hand-written mode-advantage tasks (custom, not from public benchmarks)
!benchmarks/prompts/debug/
benchmarks/prompts/debug/*
!benchmarks/prompts/debug/mode_advantage_hard.yaml

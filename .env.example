# Environment Configuration for epyc-orchestrator
# ================================================
#
# Copy this file to .env and edit paths for your system:
#   cp .env.example .env
#
# All ORCHESTRATOR_PATHS_* variables derive from LLM_ROOT by default.
# Only set LLM_ROOT and PROJECT_ROOT to relocate everything.

# =============================================================================
# BASE PATHS (Set these to relocate everything)
# =============================================================================

# Root directory for all LLM-related files (models, cache, llama.cpp, etc.)
ORCHESTRATOR_PATHS_LLM_ROOT=./local

# Project root (this repository)
ORCHESTRATOR_PATHS_PROJECT_ROOT=.

# =============================================================================
# DERIVED PATHS (Usually don't need to change these)
# =============================================================================

# Model directories
ORCHESTRATOR_PATHS_MODELS_DIR=${ORCHESTRATOR_PATHS_LLM_ROOT}/models
ORCHESTRATOR_PATHS_MODEL_BASE=${ORCHESTRATOR_PATHS_LLM_ROOT}/models

# llama.cpp binaries
ORCHESTRATOR_PATHS_LLAMA_CPP_BIN=${ORCHESTRATOR_PATHS_LLM_ROOT}/llama.cpp/build/bin
ORCHESTRATOR_PATHS_LLAMA_SERVER=${ORCHESTRATOR_PATHS_LLAMA_CPP_BIN}/llama-server
ORCHESTRATOR_PATHS_LLAMA_MTMD=${ORCHESTRATOR_PATHS_LLAMA_CPP_BIN}/llama-mtmd-cli

# Cache and temp directories
ORCHESTRATOR_PATHS_CACHE_DIR=${ORCHESTRATOR_PATHS_LLM_ROOT}/cache
ORCHESTRATOR_PATHS_TMP_DIR=${ORCHESTRATOR_PATHS_LLM_ROOT}/tmp
ORCHESTRATOR_PATHS_DRAFT_CACHE=${ORCHESTRATOR_PATHS_LLM_ROOT}/cache/drafts

# Project-specific paths
ORCHESTRATOR_PATHS_LOG_DIR=${ORCHESTRATOR_PATHS_PROJECT_ROOT}/logs
ORCHESTRATOR_PATHS_REGISTRY_PATH=${ORCHESTRATOR_PATHS_PROJECT_ROOT}/orchestration/model_registry.yaml
ORCHESTRATOR_PATHS_TOOL_REGISTRY_PATH=${ORCHESTRATOR_PATHS_PROJECT_ROOT}/orchestration/tool_registry.yaml
ORCHESTRATOR_PATHS_SCRIPT_REGISTRY_DIR=${ORCHESTRATOR_PATHS_PROJECT_ROOT}/orchestration/script_registry
ORCHESTRATOR_PATHS_SESSIONS_DIR=${ORCHESTRATOR_PATHS_PROJECT_ROOT}/orchestration/repl_memory/sessions
ORCHESTRATOR_PATHS_ARTIFACTS_DIR=${ORCHESTRATOR_PATHS_LLM_ROOT}/tmp/artifacts

# Vision paths
ORCHESTRATOR_PATHS_VISION_DIR=${ORCHESTRATOR_PATHS_LLM_ROOT}/vision

# Services paths
ORCHESTRATOR_PATHS_ARCHIVE_EXTRACT=${ORCHESTRATOR_PATHS_LLM_ROOT}/tmp/archives
ORCHESTRATOR_PATHS_PDF_ROUTER_TEMP=${ORCHESTRATOR_PATHS_LLM_ROOT}/tmp/pdf_router

# Path security (set to empty string to disable path prefix check)
ORCHESTRATOR_PATHS_RAID_PREFIX=

# =============================================================================
# ORCHESTRATOR SETTINGS
# =============================================================================

# Mock mode (set to 0 for production with real models)
ORCHESTRATOR_MOCK_MODE=1

# Registry mode: "full" (with model paths) or "lean" (routing only)
ORCHESTRATOR_REGISTRY_MODE=lean

# Debug logging
ORCHESTRATOR_DEBUG=0

# =============================================================================
# SERVER URLS (Usually don't need to change these)
# =============================================================================

# ORCHESTRATOR_SERVER_URLS_FRONTDOOR=http://localhost:8080
# ORCHESTRATOR_SERVER_URLS_CODER_ESCALATION=http://localhost:8081
# ORCHESTRATOR_SERVER_URLS_WORKER=http://localhost:8082
# ORCHESTRATOR_SERVER_URLS_ARCHITECT_GENERAL=http://localhost:8083
# ORCHESTRATOR_SERVER_URLS_ARCHITECT_CODING=http://localhost:8084
# ORCHESTRATOR_SERVER_URLS_INGEST_LONG_CONTEXT=http://localhost:8085
# ORCHESTRATOR_SERVER_URLS_WORKER_VISION=http://localhost:8086
# ORCHESTRATOR_SERVER_URLS_VISION_ESCALATION=http://localhost:8087
# ORCHESTRATOR_SERVER_URLS_API_URL=http://localhost:8000
# ORCHESTRATOR_SERVER_URLS_OCR_SERVER=http://localhost:9001
